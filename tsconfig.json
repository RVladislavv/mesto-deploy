{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "baseUrl": "./backend/src",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "outDir": "./backend/dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "typeRoots": ["./backend/@types", "./backend/node_modules/@types"]
  },
  "include": ["backend/src/**/*.ts"],
  "exclude": ["node_modules", "frontend", "backend/node_modules"]
}
